{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "workers-tsx-toolchain-spike",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-30",
  "compatibility_flags": ["nodejs_compat"],
  "rules": [
    {
      "type": "Data",
      "globs": ["**/*.wasm.bin"],
      "fallthrough": true
    }
  ],
  "worker_loaders": [
    {
      "binding": "LOADER"
    }
  ]
}
